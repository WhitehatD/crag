# Dependencies (none used, but guard against future additions)
node_modules/
package-lock.json.bak

# Assets — only public GIFs referenced by extension READMEs
# Everything else (recording scripts, casts, drafts, posts) lives in crag-cloud
assets/*
!assets/poster-demo.gif
!assets/vscode-hero.gif
!assets/vscode-compile.gif
!assets/vscode-audit.gif

# crag self-dogfooding artifacts — GENERATED, not source.
# The entire .claude/ folder is produced by `crag init` / `crag analyze` from
# the tracked sources in src/skills/, src/crag-agent.md, and scripts/. We do
# NOT track it in the crag repo to prove the tool works end-to-end: CI clones
# a bare repo, runs `crag init`/`analyze` to generate .claude/, then runs
# gates against that generated config. If tracking .claude/ feels tempting,
# remember that doing so would make the repo self-certifying by construction
# rather than by test.
.claude/

# Codex / Aider / Factory agent workflow artifacts — produced by
# `crag compile --target agents-md` as sibling output. Not source.
.agents/

# crag global cache (written to ~/.claude/crag/ but guard here too)
.crag/

# Backup files created by crag upgrade --force
*.bak.*
*.tmp.*
*.tmp.*.*

# npm pack artifacts
*.tgz

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Compile artifacts (generated by `crag compile` — ephemeral, not source)
# Keep these out of the repo itself; they belong in projects that USE crag.
# These are produced by `node bin/crag.js compile --target all` during local
# dogfooding and smoke tests. They must never be committed.
AGENTS.md
AGENTS.md.bak
GEMINI.md
GEMINI.md.bak
.cursor/
.clinerules
.clinerules.bak
.continuerules
.continuerules.bak
.windsurfrules
.windsurfrules.bak
.zed/
.sourcegraph/
.husky/
.pre-commit-config.yaml
.github/copilot-instructions.md
.github/workflows/gates.yml
# New compile targets (aider, lefthook, gitlab, coderabbit, junie, kiro, circleci, azuredevops, goose)
CONVENTIONS.md
CONVENTIONS.md.bak
lefthook.yml
lefthook.yml.bak
.gitlab-ci.yml
.coderabbit.yaml
.coderabbit.yaml.bak
.junie/
.kiro/
.goose/
.circleci/
azure-pipelines.yml
azure-pipelines.yml.bak

# Private code — lives in crag-cloud repo
/cloud/
/extensions/

