# Dependencies (none used, but guard against future additions)
node_modules/
package-lock.json.bak

# Claude Code runtime state (auto-generated)
.claude/.discovery-cache.json
.claude/.session-state.json
.claude/.gates-passed
.claude/.skill-update-check
.claude/.last-audit
.claude/.tmp/

# User-specific settings (should never be committed)
.claude/settings.local.json

# crag global cache (written to ~/.claude/crag/ but guard here too)
.crag/

# Backup files created by crag upgrade --force
*.bak.*
*.tmp.*
*.tmp.*.*

# npm pack artifacts
*.tgz

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Compile artifacts (generated by `crag compile` — ephemeral, not source)
# Keep these out of the repo itself; they belong in projects that USE crag.
# These are produced by `node bin/crag.js compile --target all` during local
# dogfooding and smoke tests. They must never be committed.
AGENTS.md
AGENTS.md.bak
GEMINI.md
GEMINI.md.bak
.cursor/
.clinerules
.clinerules.bak
.continuerules
.continuerules.bak
.windsurfrules
.windsurfrules.bak
.zed/
.sourcegraph/
.husky/
.pre-commit-config.yaml
.github/copilot-instructions.md
.github/workflows/gates.yml

# OS
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# Editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment files (should never contain secrets in this repo, but guard)
.env
.env.local
.env.*.local

# Coverage / test output (not used yet, but reserved)
coverage/
.nyc_output/
