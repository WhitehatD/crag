# Forgejo CI — compile artifact (like .github/workflows/gates.yml)
.forgejo/

# Test artifacts that may leak from benchmark fixture repos
created-by-build*.txt
should-be-added-by-build*.txt
should-be-modified-by-build*.txt
files/
link-to-a-dir
link-to-a-file

# npm lockfile — no external deps, no value
package-lock.json
