.env
.env.local
.env.*.local

# Coverage / test output (not used yet, but reserved)
coverage/
.nyc_output/

# Benchmark harness — cloned OSS repos + raw outputs (not source)
benchmarks/repos/
benchmarks/repos2/
benchmarks/repos3/
benchmarks/raw/
benchmarks/raw2/
benchmarks/raw3/
benchmarks/raw-tier2/
benchmarks/full-capability/
